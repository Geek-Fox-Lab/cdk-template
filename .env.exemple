# AWS CLI profile used by Makefile targets.
# Prefer AWS CLI profiles or SSO over storing access keys in this file.
AWS_PROFILE=default

# Default deployment region.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Lets AWS SDK/CDK read ~/.aws/config profiles, including SSO profiles.
AWS_SDK_LOAD_CONFIG=1

# Optional CDK context and stack selector.
# CONTEXT=-c environment=dev -c project_name=cdk-template
# STACK=cdk-template-dev-service
